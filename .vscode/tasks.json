{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "group": "none"
    },
    {
      "label": "npm: build",
      "type": "shell",
      "command": "npm run build",
      "group": "build"
    }
  ]
}
